BOT_TOKEN=123456:ABC-DEF...
ADMIN_USER_ID=123456789
TARGET_GROUP_CHAT_ID=-1001234567890
SUPPORT_USERNAME=

# Необязательно: антиспам в личке (секунды между принятыми сообщениями одного user_id), по умолчанию 60
# RATE_LIMIT_PRIVATE_SEC=60
# Окно для альбома (media_group): после принятого кадра столько секунд остальные кадры того же альбома не ждут паузу, по умолчанию 120
# ALBUM_BURST_WINDOW_SEC=120
# Анти-DDoS: макс. принятых сообщений за окно со всех пользователей сразу (включая в обработке), по умолчанию 10; 0 = выключить
# MAX_GLOBAL_SUBMISSIONS_PER_WINDOW=10
# Длительность окна в секундах для глобального лимита, по умолчанию 60
# GLOBAL_RATE_WINDOW_SEC=60
# Макс. длина текста/подписи от пользователя (символов), по умолчанию 12000
# MAX_USER_TEXT_CHARS=12000
# Макс. размер одного вложения (байт), по умолчанию 25 МБ (документы, видео, фото по file_size и т.д.)
# MAX_DOCUMENT_BYTES=26214400
# Если у голосового/видеокружка в API нет размера файла — лимит по длительности (сек), по умолчанию 600
# MAX_VOICE_NOTE_DURATION_SEC=600
# Видео без file_size в ответе — лимит по duration (сек), по умолчанию 600
# MAX_VIDEO_DURATION_NO_SIZE_SEC=600
